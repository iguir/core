{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(bun:*)",
      "Bash(bunx:*)",
      "Bash(tsc:*)",
      "Bash(biome:*)",
      "Bash(bunx biome:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git stash list:*)",
      "Bash(ls:*)",
      "Bash(find src:*)",
      "Bash(find tests:*)",
      "Bash(rg:*)",
      "Bash(wc:*)",
      "Bash(cat package.json)",
      "Bash(cat tsconfig.json)",
      "Bash(cat commitlint.config.mjs)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Bash(rm -rf:*)",
      "Bash(bun run release:*)",
      "Bash(bun publish:*)",
      "Bash(npm publish:*)"
    ]
  }
}
